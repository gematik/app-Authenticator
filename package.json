{
  "name": "authenticator",
  "version": "4.16.0",
  "private": true,
  "author": "Gematik GmbH",
  "description": "Authenticator Desktop Client",
  "main": "dist_electron/main.js",
  "license": "European Union Public License 1.2",
  "scripts": {
    "dev": "cross-env NODE_ENV=development webpack serve",
    "electron:build": "cross-env NODE_ENV=production webpack && electron-builder build --config builder.config.js --publish onTag",
    "mock:build": "cross-env NODE_ENV=production MOCK_MODE=ENABLED webpack && cross-env NODE_ENV=production MOCK_MODE=ENABLED electron-builder build --config builder.config.js --publish onTag",
    "jest:base": "jest --runInBand",
    "test": "npm run jest:base -- --coverage",
    "test:unit": "jest --coverage tests/unit",
    "test:integration": "npm run jest:base -- --coverage tests/integration",
    "test:watch": "npm run jest:base -- --watch",
    "test:watch:unit": "jest --watch tests/unit",
    "test:watch:integration": "npm run jest:base -- --watch tests/integration",
    "test:update-snapshots": "npm run jest:base -- --updateSnapshot tests/unit",
    "postinstall": "patch-package && node patches/electron-edge-js.js && electron-builder install-app-deps && node ./build/update-licenses.ts",
    "lint": "eslint \"./src/**/*.{vue,ts}\"",
    "lint:ci": "eslint \"./src/**/*.{vue,ts}\" --format junit --output-file ./reports/eslint-report.xml",
    "lint:fix": "eslint \"./src/**/*.{vue,ts}\" --fix",
    "update-msix-versions": "node msix/update-manifest-version.js",
    "update-certs-konnektor": "ts-node build/update-certs-konnektor.ts",
    "update-licenses": "node build/update-licenses.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gematik/app-Authenticator.git",
    "provider": "github"
  },
  "bugs": {
    "url": "https://github.com/gematik/app-Authenticator/issues"
  },
